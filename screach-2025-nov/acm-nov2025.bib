doi = {10.1145/1551950.1551953},
abstract = {Multimedia Communications, Virtual Environments, Haptics and Gestural Interfaces have been in the forefront of Information Technology for a few years now, but only recently have seen numerous applications in many areas.This presentation will give an introduction to the field of Distributed and Collaborative Hapto-Virtual Environments, with applications in e-Learning, Industrial Training and Medical Education, particularly highlighting the relevant research in the Distributed and Collaborative Virtual Environments Research laboratory (DISCOVER) of the speaker at the University of Ottawa.},
booktitle = {Proceedings of the 2009 Conference on Information Science, Technology and Applications},
